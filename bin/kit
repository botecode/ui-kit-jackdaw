#!/usr/bin/env bash
#
# kit — the UI-kit build loop. ONE command builds a component and merges it to main, live.
#
#   kit next            grab the next "Next" kit card, build it, gate, merge to main.
#   kit launch <name>   build one component, gate (tsc+vitest), merge to main. No PR, no test step.
#   kit fix <name> "…"  modify an already-shipped component IN PLACE per "…", gate, merge to main.
#   kit gallery         run the gallery (npm run dev) on main — keep this open; merges hot-reload it.
#
# Cards live on the Build Board (Kind=kit), comment-only: the card's comment is the spec.
# Install once:  ln -sf /Users/fernandofeitosa/dev/ui-jackdaw/bin/kit /usr/local/bin/kit
# Move the repo? set KIT_ROOT in your shell.
#
set -euo pipefail

KIT_ROOT="${KIT_ROOT:-/Users/fernandofeitosa/dev/ui-jackdaw}"
[ -d "$KIT_ROOT" ] || { echo "KIT_ROOT not found: $KIT_ROOT (set KIT_ROOT env)" >&2; exit 1; }
R="$KIT_ROOT"
ROLE_FILE="$R/prompts/roles/kit-agent.md"

# Stay in cwd if it's inside the kit repo; otherwise jump to the primary checkout.
in_repo=0
if gc="$(git -C "$PWD" rev-parse --git-common-dir 2>/dev/null)"; then
  case "$gc" in /*) : ;; *) gc="$PWD/$gc" ;; esac
  [ "$(cd "$(dirname "$gc")" && pwd)" = "$R" ] && in_repo=1
fi
[ "$in_repo" = "1" ] || cd "$R"

# Best-effort Build Board move; surfaces WHY it couldn't (token/card/API) instead of failing silently.
jdstatus() {
  local out
  if out="$(python3 "$R/scripts/run-card.py" --set-status "$1" "$2" 2>&1)"; then
    echo "  · board: $1 → $2"
  else
    echo "  · board: couldn't set $1 → $2 — ${out##*$'\n'}" >&2
  fi
}

# Build one component on its own branch, gate it, and MERGE it into main in place — so the gallery
# you have open on main hot-reloads and you see it live. No PR, no separate test step.
ship() {
  local name="$1" feedback="${2:-}" nocontext="${3:-}" wt br spec prompt rc f cur msg ctx HARGS
  br="kit/$name"; wt="$R/.worktrees/$name"
  [ -f "$ROLE_FILE" ] || { echo "Missing role preamble: $ROLE_FILE" >&2; return 1; }

  # We merge into main in place, so the primary checkout must be on a clean main.
  cur="$(git -C "$R" rev-parse --abbrev-ref HEAD)"
  [ "$cur" = main ] || { echo "Primary checkout is on '$cur', not 'main' — switch to main first (we merge there)." >&2; return 1; }
  [ -z "$(git -C "$R" status --porcelain --untracked-files=no)" ] \
    || { echo "main has uncommitted changes — commit/stash them first (we merge into main in place)." >&2; return 1; }

  spec="$(mktemp -t kit-"$name".XXXX.md)"
  if [ -n "$feedback" ]; then
    # FIX mode: the change request IS the spec (modify in place, don't rebuild).
    printf '# Change requested for the existing `%s` component (modify in place, do NOT rebuild)\n\n%s\n' "$name" "$feedback" >"$spec"
    # Ad-hoc `kit fix <name> "note"` → append the component's original card spec as context.
    # A fix CARD (nocontext=1) already passed the card comment AS the feedback — don't append it twice.
    if [ -z "$nocontext" ]; then
      ctx="$(python3 "$R/scripts/run-card.py" --instructions "$name" 2>/dev/null || true)"
      [ -n "$ctx" ] && printf '\n\n---\n# Original card spec (context — honor it, do not re-do it)\n\n%s\n' "$ctx" >>"$spec"
    fi
  else
    # BUILD mode: the card's comments (comment-only); fall back to a committed spec file.
    python3 "$R/scripts/run-card.py" --instructions "$name" >"$spec" 2>/dev/null || true
    if [ ! -s "$spec" ]; then
      for f in "$R/docs/superpowers/specs/$name.md" "$R/docs/superpowers/plans/$name.md" "$R/prompts/$name.md"; do
        [ -f "$f" ] && { cp "$f" "$spec"; break; }
      done
    fi
    [ -s "$spec" ] || { echo "No card comments and no spec file for '$name' — shape the card first." >&2; rm -f "$spec"; return 1; }
  fi

  # Fresh worktree off the current main (wipe any stale one from a prior run).
  [ -d "$wt" ] && git -C "$R" worktree remove --force "$wt" 2>/dev/null || true
  git -C "$R" branch -D "$br" 2>/dev/null || true
  git -C "$R" worktree add -B "$br" "$wt" main

  prompt="$wt/.agent-prompt.md"
  HARGS="${CLAUDE_HEADLESS_ARGS:---permission-mode bypassPermissions --verbose}"
  if [ -n "$feedback" ]; then
    { cat "$ROLE_FILE"; printf '\n\n---\n\n# Modify the EXISTING component (do NOT rebuild)\n\n'; cat "$spec"; } >"$prompt"
    msg="Apply the change in .agent-prompt.md to the EXISTING $name component that is already in this repo — MODIFY it in place, do NOT rebuild it from scratch. You are HEADLESS and NON-INTERACTIVE — never ask questions; decide every choice via KIT-LEAD.md and proceed. Keep the change minimal + on-scope, update the demo + tests for what you change, keep everything green, and COMMIT. Drive with /superpowers."
    echo "▶ fixing $name on $br (headless)…"
  else
    { cat "$ROLE_FILE"; printf '\n\n---\n\n# Your task (this card)\n\n'; cat "$spec"; } >"$prompt"
    msg="Implement .agent-prompt.md end to end. You are running HEADLESS and NON-INTERACTIVE — there is NO human to reply, so do NOT ask questions, request approval, or pause to confirm a design choice (that just ends the run with nothing built). When something is ambiguous, decide it yourself using KIT-LEAD.md, pick the most Chroma-consistent option, record the decision and reasoning in your commit message, and keep going until the component is built, all its states are in the gallery demo, its own tests pass, and everything is committed. Drive the work with /superpowers (plan, spec, build)."
    echo "▶ building $name on $br (headless)…"
  fi
  ( cd "$wt" && claude -p "$msg" $HARGS 2>&1 | tee "$wt/.agent.log" )
  rc=${PIPESTATUS[0]}
  [ "$rc" = 0 ] || { echo "✗ agent exited $rc — see $wt/.agent.log" >&2; return 1; }

  # Anti-vacuum guards: a headless agent that stopped to ask leaves zero commits; one that only
  # planned leaves no component. Don't let a vacuous run sail through a green full-suite gate.
  if ! git -C "$wt" rev-list -n1 "main..HEAD" 2>/dev/null | grep -q .; then
    echo "✗ no new commits on $br — the agent built nothing (it likely stopped to ask). See $wt/.agent.log." >&2; return 1
  fi
  if [ -n "$feedback" ]; then
    git -C "$wt" diff --name-only "main..HEAD" -- src/components/ 2>/dev/null | grep -q . \
      || { echo "✗ nothing changed under src/components/ on $br — the fix didn't land. See $wt/.agent.log." >&2; return 1; }
  else
    git -C "$wt" diff --name-only "main..HEAD" -- src/components/ 2>/dev/null | grep -q '\.test\.' \
      || { echo "✗ no new component test under src/components/ on $br — the agent planned but didn't build. See $wt/.agent.log." >&2; return 1; }
  fi

  # Objective gate (don't trust the agent's self-report).
  echo "▶ gate: npm install + tsc + vitest"
  ( cd "$wt" && npm install --silent && npx tsc --noEmit && npx vitest run ) \
    || { echo "✗ gate failed (tsc/vitest red) — $br left for inspection, NOT merged." >&2; return 1; }

  # Merge into main in place (ff if we can, else a merge commit). On conflict ABORT so main is NEVER
  # left mid-conflict — that's what stranded files + broke the next run.
  echo "▶ merging $br → main"
  if ! git -C "$R" merge --ff-only "$br" 2>/dev/null; then
    git -C "$R" merge --no-edit "$br" || {
      git -C "$R" merge --abort 2>/dev/null || true
      echo "✗ merge into main conflicted — aborted, main restored clean. '$br' kept for review." >&2
      echo "  (usually means '$name' was already built/merged — its card should be Done, not Next.)" >&2
      return 1
    }
  fi
  git -C "$R" push origin main 2>/dev/null && echo "  · pushed origin main" \
    || echo "  · (didn't push origin main — push manually to back it up)"
  git -C "$R" worktree remove --force "$wt" 2>/dev/null || true
  git -C "$R" branch -D "$br" 2>/dev/null || true

  # Rebuild the library so consumers see the new component immediately: the DAW imports
  # @jackdaw/kit → dist/, and dist/ is gitignored, so this refreshes the local artifact the
  # file: link points at. Doubles as a final build check on main (vite lib + lib tsconfig).
  echo "▶ build:lib (refresh dist/ for the DAW)"
  ( cd "$R" && npm run build:lib ) \
    && echo "  · dist/ rebuilt — the DAW's @jackdaw/kit link now sees $name" \
    || echo "  · ⚠ build:lib failed on main — fix it, then run 'npm run build:lib' manually."

  echo "✓ $name is on main — live in the gallery (run 'kit gallery' if it isn't open)."
}

# Build OR fix a card based on its Kind: Kind=fix → modify the existing component in place, using the
# card's comment as the change request; otherwise build a new component. (Kit cards are picked by
# Roles=kit, so a fix card is Kind=fix + Roles=["kit"].)
ship_card() {
  local name="$1" kind fb
  kind="$(python3 "$R/scripts/run-card.py" --meta "$name" 2>/dev/null | awk '{print $1}')"
  if [ "$kind" = fix ]; then
    fb="$(python3 "$R/scripts/run-card.py" --instructions "$name" 2>/dev/null || true)"
    [ -n "$fb" ] || { echo "✗ fix card '$name' has no comment describing the fix — shape it first." >&2; return 1; }
    echo "  · '$name' is a fix card → modifying the existing component in place"
    ship "$name" "$fb" 1
  else
    ship "$name"
  fi
}

cmd="${1:-}"; [ $# -gt 0 ] && shift || true
case "$cmd" in
  next)
    name="$(python3 "$R/scripts/run-card.py" --print-next)" || exit 1
    [ -n "$name" ] || { echo "No kit card in Next." >&2; exit 1; }
    echo "▶ next kit card → $name"
    jdstatus "$name" "In Progress"
    ship_card "$name" && jdstatus "$name" "Done" || { jdstatus "$name" "Next"; exit 1; } ;;

  launch|build|ship)
    name="${1:-}"; [ -n "$name" ] || { echo "usage: kit launch <name>" >&2; exit 1; }
    jdstatus "$name" "In Progress"
    ship_card "$name" && jdstatus "$name" "Done" || { jdstatus "$name" "Next"; exit 1; } ;;

  fix)
    name="${1:-}"; note="${2:-}"
    [ -n "$name" ] && [ -n "$note" ] || { echo "usage: kit fix <name> \"<change to make>\"" >&2; exit 1; }
    ship "$name" "$note" ;;

  gallery)
    cd "$R"; exec npm run dev ;;

  ""|-h|--help|help)
    sed -n '3,13p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
  *) echo "Unknown command '$cmd'. Run: kit help" >&2; exit 1 ;;
esac
