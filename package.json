{
  "name": "@jackdaw/kit",
  "version": "1.0.0",
  "description": "Jackdaw UI kit — the Chroma design system, consumed by the DAW.",
  "type": "module",
  "main": "./dist/jackdaw-kit.js",
  "module": "./dist/jackdaw-kit.js",
  "types": "./dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/jackdaw-kit.js"
    },
    "./styles.css": "./dist/jackdaw-kit.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "public/fonts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "vite build -c vite.lib.config.ts && npm run build:types",
    "build:types": "tsc -p tsconfig.lib.json",
    "test": "vitest",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "uqr": "^0.1.3"
  }
}
